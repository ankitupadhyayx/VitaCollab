NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vitacollab
MONGO_URI=mongodb://localhost:27017/vitacollab
CLIENT_URL=https://vitacollab.in
APP_URL=https://vitacollab.in
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
JWT_SECRET=replace_with_strong_random_secret
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENABLE_WEBSOCKET=false
REFRESH_COOKIE_NAME=refreshToken
REFRESH_COOKIE_SAMESITE=none
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_DOMAIN=.vitacollab.in
CORS_ORIGINS=https://vitacollab.in,https://www.vitacollab.in
AES_SECRET_KEY=replace_with_32_char_secret_key
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RECORD_UPLOAD_MAX_MB=5
CLAMAV_ENABLED=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
RECORD_SHARE_DEFAULT_EXPIRY_MINUTES=20
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace_with_strong_admin_password
LOG_LEVEL=info
